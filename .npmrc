engine-strict=true

# onnxruntime-node (via @huggingface/transformers) has a postinstall that
# downloads ~300MB of CUDA binaries on linux-x64 by default — on every npm ci,
# in every workflow. We run CPU-only; skip it. Both flag spellings cover the
# pre-1.22 and post-1.22 names.
onnxruntime-node-install-cuda=skip
onnxruntime-node-install=skip
