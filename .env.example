# ── Local .env for running the pipeline locally ──────────────────────────────
# (node --import tsx --env-file=.env scripts/run-pipeline.ts)
#
# In production these live in three places (see README):
#   • Pipeline   → GitHub repo Secrets (used by .github/workflows/pipeline.yml)
#   • Frontend   → build env: PUBLIC_SUPABASE_* (deploy.yml)
#   • Edge fns   → `supabase secrets set` for LLM_* (reader/translate)

# Supabase — server (service role; never expose to the browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Supabase — browser (public; safe to ship in the static bundle)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# LLM — OpenAI-compatible (classification, clustering, trending, translation)
# Cerebras free tier: https://cloud.cerebras.ai  (30K tokens/min, 1M tokens/day)
LLM_BASE_URL=https://api.cerebras.ai/v1
LLM_API_KEY=your_cerebras_api_key_here
LLM_MODEL=gpt-oss-120b
# Alternatives: LLM_MODEL=zai-glm-4.7  | or Groq: LLM_BASE_URL=https://api.groq.com/openai/v1, LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
